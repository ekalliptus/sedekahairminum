---
import { getSeoSettings, buildTitle } from '@/lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  rawTitle?: boolean; // skip the global separator (article pages pass a fully-formed title)
}

const { title, description, canonical, ogImage, rawTitle = false } = Astro.props;
const siteUrl = 'https://sedekahairminum.com';
const seo = await getSeoSettings(Astro.locals?.supabase ?? null);

const resolvedTitle = rawTitle ? title : buildTitle(title, seo);
const finalDescription = description || seo.homepage_description;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage || seo.default_og_image || `${siteUrl}/assets/hero/DSC00529_4_11zon.webp`;
const robotsContent = seo.robots_index ? 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' : 'noindex, nofollow';
const ga4Id = seo.ga4_id?.trim();
const twitterHandle = seo.twitter_handle?.trim() || '';
---
<!doctype html>
<html lang="id" data-theme="dark" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <script is:inline>
    (function(){var s=localStorage.getItem('sam-theme');if(s){document.documentElement.setAttribute('data-theme',s);document.documentElement.classList.toggle('dark',s==='dark');}})();
  </script>
  <title>{resolvedTitle}</title>
  <meta name="description" content={finalDescription} />
  <link rel="canonical" href={canonicalUrl} />

  {/* Search-engine verification tags (Rank Math SEO settings). */}
  {seo.gsc_verification?.trim() && (
    <meta name="google-site-verification" content={seo.gsc_verification.trim()} />
  )}
  {seo.bing_verification?.trim() && (
    <meta name="msvalidate.01" content={seo.bing_verification.trim()} />
  )}

  <!-- Security -->
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />

  <meta name="theme-color" content="#050d14" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#f4f7f9" media="(prefers-color-scheme: light)" />
  <meta name="color-scheme" content="dark light" />
  <meta name="robots" content={robotsContent} />
  <meta name="author" content="Yayasan Gerakan Wakaf Sumur" />
  <meta name="publisher" content="Sedekah Air Minum" />
  <meta name="geo.region" content="ID-YO" />
  <meta name="geo.placename" content="Gunung Kidul, DI Yogyakarta" />
  <meta name="geo.position" content="-7.955;110.58" />
  <meta name="ICBM" content="-7.955, 110.58" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:site_name" content="Sedekah Air Minum" />
  <meta property="og:title" content={resolvedTitle} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Armada Sedekah Air Minum — Gerakan Wakaf Air Bersih" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={resolvedTitle} />
  <meta name="twitter:description" content={finalDescription} />
  <meta name="twitter:image" content={ogImageUrl} />
  {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
  {seo.facebook_app_id?.trim() && <meta property="fb:app_id" content={seo.facebook_app_id.trim()} />}

  {/* Google Analytics 4 (Rank Math SEO settings) — only when a Measurement ID is set. */}
  {ga4Id && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>}
  {ga4Id && (
    <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}');`} />
  )}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/assets/logo.webp" />

  <!-- Fonts — preload critical -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://basemaps.cartocdn.com" crossorigin />
  <link rel="dns-prefetch" href="https://basemaps.cartocdn.com" />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
  />

  <!-- Structured Data: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NGO",
    "name": "Yayasan Gerakan Wakaf Sumur",
    "alternateName": ["Sedekah Air Minum", "SAM", "GWS"],
    "url": siteUrl,
    "logo": `${siteUrl}/assets/logo.webp`,
    "image": ogImageUrl,
    "description": "Gerakan wakaf air bersih untuk masjid, pesantren, dan lembaga pendidikan Islam di Gunung Kidul, DI Yogyakarta. Sedekah jariyah yang terus mengalir.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Karang Duwet II, Karangrejek",
      "addressLocality": "Wonosari",
      "addressRegion": "Gunung Kidul, DI Yogyakarta",
      "addressCountry": "ID"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -7.955,
      "longitude": 110.58
    },
    "telephone": "+6285319480974",
    "email": "gerakansumur@gmail.com",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+6285319480974",
      "contactType": "customer service",
      "availableLanguage": "Indonesian"
    },
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": "Kabupaten Gunung Kidul, DI Yogyakarta, Indonesia"
    },
    "foundingDate": "2022",
    "numberOfEmployees": { "@type": "QuantitativeValue", "value": 19, "unitText": "lembaga penerima" },
    "knowsAbout": ["wakaf air", "sedekah air minum", "distribusi air bersih", "pesantren", "gerakan wakaf sumur"],
    "sameAs": []
  })} />

  <!-- Structured Data: WebSite (for sitelinks search) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sedekah Air Minum",
    "url": siteUrl,
    "inLanguage": "id",
    "publisher": {
      "@type": "Organization",
      "name": "Yayasan Gerakan Wakaf Sumur"
    }
  })} />

  <!-- Structured Data: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Beranda", "item": siteUrl },
      ...(Astro.url.pathname !== '/' ? [{ "@type": "ListItem", "position": 2, "name": title.split(' — ')[0], "item": canonicalUrl }] : [])
    ]
  })} />

  <style is:global>
    @import '../styles/global.css';
    @import '../styles/tailwind.css';
  </style>

  <!-- Navigation loading bar: shows while an SSR page is being requested
       (cache miss). Instant on cache hit. -->
  <style is:inline>
    #nav-loader{position:fixed;top:0;left:0;height:2px;width:0;background:var(--aqua);
      box-shadow:0 0 8px var(--aqua);z-index:9999;opacity:0;transition:opacity .2s}
    #nav-loader.show{opacity:1;animation:navload 1.2s ease-out forwards}
    @keyframes navload{0%{width:0}50%{width:70%}100%{width:100%}}
  </style>
</head>
<body>
  <div id="nav-loader"></div>
  <a href="#main-content" class="skip-link">Langsung ke konten</a>
  <slot />

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.fade-up:not(.in)').forEach(el => observer.observe(el));
    });

    // Navigation loading bar: trigger on internal link clicks, hide when page loads.
    (function () {
      const loaderEl = document.getElementById('nav-loader');
      if (!loaderEl) return;
      const loader = loaderEl;
      function show() { loader.classList.remove('show'); void loader.offsetWidth; loader.classList.add('show'); }
      function hide() { loader.classList.remove('show'); }
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement)?.closest('a');
        if (!a) return;
        const href = a.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:') || a.target === '_blank') return;
        if (a.hasAttribute('download')) return;
        if (href === window.location.href || href === window.location.pathname) return;
        show();
      });
      window.addEventListener('load', hide);
      document.addEventListener('astro:page-load', hide);
      setTimeout(hide, 3000);
    })();
  </script>
</body>
</html>
